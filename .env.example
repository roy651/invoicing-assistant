# Copy to .env for local development ONLY. Never commit a real .env.
# In production (Cowork on the user's Mac), credentials live in the macOS Keychain,
# not in a .env file. This template exists for sandbox bridge development.

# --- morning (Green Invoice) API ---
# Generate in the morning account settings. Sandbox keys for development.
MORNING_ENV=sandbox            # sandbox | live
MORNING_API_KEY_ID=replace_me
MORNING_API_SECRET=replace_me

# --- IMAP (read-only) ---
# Host/user from the mail provider; use an app-password, not the main password.
# In production these come from Keychain, not here.
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=replace_me
IMAP_APP_PASSWORD=replace_me

# --- Google Sheets (state store) ---
# Sheet IDs are config, not secrets. Drive access is via the Cowork connector OAuth.
PRICEBOOK_SHEET_ID=replace_me
LEDGER_SHEET_ID=replace_me
CLIENT_PROFILES_SHEET_ID=replace_me
AGREEMENTS_SHEET_ID=replace_me

# --- Behavior flags ---
DRY_RUN=true                   # true = bridge reports what it WOULD create, creates nothing
